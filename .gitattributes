# Default: auto-detect line endings, treat as text
* text=auto

# Source code — always LF
*.py text eol=lf
*.js text eol=lf
*.java text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.xml text eol=lf

# Shell / Maven / Docker
Dockerfile text eol=lf
Makefile text eol=lf
*.dockerfile text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary — never diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.class binary
*.so binary
*.dylib binary
*.dll binary
