# Care Manager workflow backend — environment variable template.
# Copy to .env and fill in values. NEVER commit a real .env file.

# AWS
AWS_REGION=us-east-1

# Bedrock Agent (from care-manager-workflow CFN stack outputs)
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# Optional: surface a scrubbed trace summary to the frontend for debug UI
ENABLE_TRACE=false

# CORS — set to your CloudFront distribution domain in production
CORS_ORIGINS=http://localhost:8080,https://your-cloudfront-distribution.cloudfront.net

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
DEBUG=false
