# Provider workflow backend — environment variable template.
# Copy to .env and fill in values. NEVER commit a real .env file.

# AWS
AWS_REGION=us-east-1
# AWS_PROFILE=                                # leave blank for default chain

# HealthLake (from shared infrastructure stack outputs)
HEALTHLAKE_DATASTORE_ID=

# Connect Health domain (from shared infrastructure stack outputs)
DOMAIN_ID=
SERVICE_NAME=connecthealth
SERVICE_ENDPOINT=                              # leave blank to use the default endpoint

# Amazon S3
S3_OUTPUT_BUCKET=                              # from shared infrastructure stack outputs
STREAMING_OUTPUT_BUCKET=                       # optional; falls back to S3_OUTPUT_BUCKET
STREAMING_OUTPUT_REGION=us-east-1

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=4096

# Bedrock Guardrails (REQUIRED for any deployment touching real PHI)
# Get these from the healthcare-guardrail.yaml stack outputs
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# SMS (provider workflow's after-visit-summary notification)
SMS_AWS_PROFILE=
SMS_REGION=us-east-1
SMS_ORIGINATION_NUMBER=

# Demo cache mapping (only for live recording — ignore for normal use)
DEMO_CACHE_PATIENT_A=
DEMO_CACHE_PATIENT_B=
DEMO_CACHE_PATIENT_C=

# CORS — lock down in production
CORS_ORIGINS=http://localhost:5000,https://your-cloudfront-distribution.cloudfront.net

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=false

# Cognito (leave blank to disable auth; required for production)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
