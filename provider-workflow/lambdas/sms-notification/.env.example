# SMS notification Lambda — environment variable template.

SESSION_METADATA_BUCKET=                       # S3 bucket with session metadata
CLINIC_PHONE=(555) 010-0102                    # display number; use 555-01xx range
DEMO_PHONE_OVERRIDE=                           # if set, all SMS go to this number
SMS_ORIGINATION_NUMBER=                        # SNS sender ID
AWS_REGION=us-east-1
